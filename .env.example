# Credenciais OAuth2 do Bling
# Obtidos em: Bling > Configuracoes > API > Meus Aplicativos
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=seu_client_secret_aqui

# Tokens OAuth2
# access_token: obtido via fluxo OAuth, expira em 1 hora
# refresh_token: obtido junto com o access_token, usado para renovar
BLING_ACCESS_TOKEN=seu_access_token_aqui
BLING_REFRESH_TOKEN=seu_refresh_token_aqui

# Seguranca: chave que o BotConversa vai enviar no header X-API-Key
API_SECRET_KEY=gere_uma_chave_aleatoria_forte_aqui

# Porta do servidor (Railway/Render injetam PORT automaticamente)
PORT=3000
